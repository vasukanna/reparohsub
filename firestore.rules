rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    // Collection: users
    // Fields: uid, displayName, email, photoURL, role, createdAt, phoneNumber, location, subscriptionEndsAt
    //
    // Collection: workers
    // Fields: uid, name, category, skills, experience, pricing, location, district, phone, rating, reviewCount, isFeatured, isSubscribed, bio, status
    //
    // Collection: bookings
    // Fields: customerId, workerId, category, date, time, status, createdAt, customerName, workerName, notes
    //
    // Collection: reviews
    // Fields: workerId, customerId, customerName, rating, comment, createdAt
    //
    // Collection: categories
    // Fields: name, icon, slug
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
          (request.auth.token.email == "naren.papanaboina@gmail.com" && request.auth.token.email_verified == true));
    }

    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }

    function isValidUser(data) {
      return data.uid is string &&
             data.email is string &&
             data.role in ['customer', 'worker', 'admin'];
    }

    function isValidWorker(data) {
      return data.uid is string &&
             data.name is string &&
             data.category is string &&
             data.location is string;
    }

    function isValidBooking(data) {
      return data.customerId is string &&
             data.workerId is string &&
             data.status in ['pending', 'accepted', 'rejected', 'completed', 'cancelled'];
    }

    function isValidReview(data) {
      return data.workerId is string &&
             data.customerId is string &&
             data.rating is number && data.rating >= 1 && data.rating <= 5;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{uid} {
      allow read: if isAuthenticated() && (isOwner(uid) || isAdmin());
      allow create: if isAuthenticated() && isOwner(uid) && isValidUser(request.resource.data);
      allow update: if isAuthenticated() && (isOwner(uid) || isAdmin()) && isValidUser(request.resource.data);
      allow delete: if isAdmin();
    }

    match /workers/{uid} {
      allow read: if true; // Publicly searchable
      allow create: if isAuthenticated() && (isOwner(uid) || isAdmin()) && isValidWorker(request.resource.data);
      allow update: if isAuthenticated() && (isOwner(uid) || isAdmin()) && isValidWorker(request.resource.data);
      allow delete: if isAdmin();
    }

    match /bookings/{bookingId} {
      allow read: if isAuthenticated() && (request.auth.uid == resource.data.customerId || request.auth.uid == resource.data.workerId || isAdmin());
      allow create: if isAuthenticated() && request.auth.uid == request.resource.data.customerId && isValidBooking(request.resource.data);
      allow update: if isAuthenticated() && (request.auth.uid == resource.data.customerId || request.auth.uid == resource.data.workerId || isAdmin()) && isValidBooking(request.resource.data);
      allow delete: if isAdmin();
    }

    match /reviews/{reviewId} {
      allow read: if true;
      allow create: if isAuthenticated() && request.auth.uid == request.resource.data.customerId && isValidReview(request.resource.data);
      allow update: if isAuthenticated() && (request.auth.uid == resource.data.customerId || isAdmin()) && isValidReview(request.resource.data);
      allow delete: if isAdmin();
    }

    match /categories/{categoryId} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
